# ══════════════════════════════════════════════════════
# ParSEC Smart Ticketing — Production Environment Template
# Copy this to .env and fill in all values
# ══════════════════════════════════════════════════════

APP_NAME="ParSEC Tickets"
APP_ENV=production          # NEVER set to "local" in production
APP_KEY=                    # Run: php artisan key:generate
APP_DEBUG=false             # CRITICAL: must be false in production
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error             # Use "error" in production, not "debug"

# ── Database ──────────────────────────────────────────
# NEVER use root in production — create a dedicated DB user
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=parsec_tickets
DB_USERNAME=parsec_db_user  # Change this
DB_PASSWORD=                # Set a strong password

# ── Sessions & Cache ──────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true        # Enable for production
SESSION_PATH=/
SESSION_DOMAIN=your-domain.com
SESSION_SECURE_COOKIE=true  # Requires HTTPS

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tickets@paramfoundation.org
MAIL_PASSWORD=              # Your Gmail App Password
MAIL_FROM_ADDRESS=tickets@paramfoundation.org
MAIL_FROM_NAME="ParSEC Tickets"

# ── Razorpay ──────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_live_* keys in production
RAZORPAY_KEY=rzp_live_xxxxxxxxxxxx
RAZORPAY_SECRET=            # Keep this SECRET — never expose to frontend

# ── WhatsApp ──────────────────────────────────────────
# Interakt: https://app.interakt.ai/developer-docs
# OR WATI: https://docs.wati.io/
WHATSAPP_TOKEN=
WHATSAPP_URL=https://api.interakt.ai/v1/public/message/

# ── Scanner PIN ───────────────────────────────────────
# Use a 6-digit PIN — change from default 1234!
SCANNER_PIN=

# ── Vite ──────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
# DO NOT add VITE_RAZORPAY_KEY — it exposes your key in public JS bundle
